BOT_TOKEN=your_telegram_bot_token
GOOGLE_SHEETS_SPREADSHEET_ID=your_google_spreadsheet_id
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@project-id.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-5-mini
DEFAULT_TIMEZONE=Europe/Moscow

# ─── Точка Банк (webhook, необязательно) ─────────────────────────────────────
# Telegram chat ID для уведомлений о поступлениях (узнать у @userinfobot).
# Достаточно одного этого параметра, чтобы поднять webhook-сервер.
TOCHKA_NOTIFY_CHAT_ID=your_telegram_chat_id

# JWT-токен Точки — нужен ТОЛЬКО для одноразовой регистрации webhook
# (npm run tochka:register). В рантайме боту не нужен.
TOCHKA_JWT_TOKEN=your_jwt_token
TOCHKA_CUSTOMER_CODE=your_customer_code

# Порт HTTP-сервера. На Railway PORT задаётся автоматически.
# PORT=3000
